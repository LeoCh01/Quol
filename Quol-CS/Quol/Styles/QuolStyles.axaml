<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <SolidColorBrush x:Key="QuolTitleBarBrush">#222222</SolidColorBrush>
    <SolidColorBrush x:Key="QuolContentBrush">#444444</SolidColorBrush>
    <SolidColorBrush x:Key="QuolButtonBrush">#333333</SolidColorBrush>
    <SolidColorBrush x:Key="QuolButtonHoverBrush">#555555</SolidColorBrush>
    <SolidColorBrush x:Key="QuolButtonPressedBrush">#666666</SolidColorBrush>
    <SolidColorBrush x:Key="QuolButtonBorderBrush">#444444</SolidColorBrush>
    <SolidColorBrush x:Key="QuolDangerBrush">#CC4444</SolidColorBrush>
    <SolidColorBrush x:Key="QuolDangerHoverBrush">#DD5555</SolidColorBrush>
    <SolidColorBrush x:Key="QuolForegroundBrush">White</SolidColorBrush>
    <SolidColorBrush x:Key="QuolMutedForegroundBrush">#DDDDDD</SolidColorBrush>

