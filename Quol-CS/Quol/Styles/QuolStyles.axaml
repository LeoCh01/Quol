  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource QuolForegroundBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="{StaticResource QuolButtonBrush}" />
    <Setter Property="Foreground" Value="{StaticResource QuolForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource QuolButtonBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="5,5" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{StaticResource QuolButtonHoverBrush}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{StaticResource QuolButtonPressedBrush}" />
  </Style>

  <Style Selector="Button.titlebar-icon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Background" Value="{StaticResource QuolDangerBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource QuolDangerBrush}" />
  </Style>

  <Style Selector="Button.danger:pointerover">
    <Setter Property="Background" Value="{StaticResource QuolDangerHoverBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource QuolDangerHoverBrush}" />
  </Style>

  <Style Selector="PathIcon">
    <Setter Property="Foreground" Value="{StaticResource QuolForegroundBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.icon PathIcon">
    <Setter Property="Width" Value="12" />
    <Setter Property="Height" Value="12" />
  </Style>

  <Style Selector="Button.titlebar-icon PathIcon">
    <Setter Property="Width" Value="12" />
    <Setter Property="Height" Value="12" />
  </Style>

  <!-- Grid / StackPanel / layout defaults -->
  <Style Selector="Grid">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="StackPanel">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <!-- Inputs -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="#3D3D3D" />
    <Setter Property="Foreground" Value="{StaticResource QuolForegroundBrush}" />
    <Setter Property="BorderBrush" Value="#555555" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="6,3" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="#777777" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{StaticResource QuolButtonBrush}" />
    <Setter Property="Foreground" Value="{StaticResource QuolForegroundBrush}" />
    <Setter Property="BorderBrush" Value="#555555" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <!-- ListBox -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="{StaticResource QuolButtonBrush}" />
    <Setter Property="Foreground" Value="{StaticResource QuolForegroundBrush}" />
    <Setter Property="BorderBrush" Value="#555555" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="6,3" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{StaticResource QuolForegroundBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#3D3D3D" />
  </Style>

  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="#555555" />
  </Style>

  <!-- CheckBox -->
  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{StaticResource QuolForegroundBrush}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <!-- Separator -->
  <Style Selector="Separator">
    <Setter Property="Background" Value="#555555" />
    <Setter Property="Height" Value="1" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Margin" Value="0,4" />
  </Style>

  <!-- TabControl -->
  <Style Selector="TabControl">
    <Setter Property="Background" Value="{StaticResource QuolContentBrush}" />
    <Setter Property="BorderBrush" Value="#555555" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="TabItem">
    <Setter Property="Background" Value="{StaticResource QuolButtonBrush}" />
    <Setter Property="Foreground" Value="{StaticResource QuolForegroundBrush}" />
    <Setter Property="BorderBrush" Value="#555555" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Padding" Value="11,4" />
  </Style>

  <Style Selector="TabItem:selected">
    <Setter Property="Background" Value="{StaticResource QuolContentBrush}" />
  </Style>

  <Style Selector="TabItem:pointerover">
    <Setter Property="Background" Value="#3D3D3D" />
  </Style>

  <!-- ScrollBar -->
  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="{StaticResource QuolContentBrush}" />
  </Style>

  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="#666666" />
  </Style>

  <Style Selector="ScrollBar:pointerover /template/ Thumb">
    <Setter Property="Background" Value="#777777" />
  </Style>

  <!-- ToolTip -->
  <Style Selector="ToolTip">
    <Setter Property="Background" Value="{StaticResource QuolButtonBrush}" />
    <Setter Property="Foreground" Value="{StaticResource QuolMutedForegroundBrush}" />
    <Setter Property="BorderBrush" Value="#555555" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="6,3" />
    <Setter Property="FontSize" Value="11" />
  </Style>

</Styles>
